# .env 파일

# Django 설정
SECRET_KEY=changeme
DEBUG=True
ALLOWED_HOSTS=*

# DB 설정 (Docker용)
# 중요: HOST는 docker-compose의 서비스 이름인 'tm_db'여야 합니다.
POSTGRES_DB=tm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=tm_db
POSTGRES_PORT=5432

# API 통신 테스트용 
ACCESS_TOKEN=changeme
AI_API_URL=http://host.docker.internal:8000
