{
  "expo": {
    "name": "글로벌비전 TM파트너", 
    "slug": "tm_mob",
    "version": "1.0.1", 
    "orientation": "portrait",
    "icon": "./assets/TM_app_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/TM_app_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.globalvision.tmpartner",
      "versionCode": 2,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/TM_app_icon.png",
        "backgroundColor": "#E6F4FE"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7084e755-70f5-452a-a876-666edd6d2f3b"
      }
    }
  }
}